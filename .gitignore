# Ignore everything by default
*

# Allow these specific files at root
!.gitignore
!.env.example
!CLAUDE.md

# Claude Code settings
!.claude/
!.claude/**

# ========================================
# Ubuntu node (Docker stack)
# ========================================
!ubuntu/
!ubuntu/.env.example

# Main compose files
!ubuntu/compose.yml
!ubuntu/media-compose.yml

# Caddy reverse proxy config
!ubuntu/caddy/
!ubuntu/caddy/Caddyfile
!ubuntu/caddy/Dockerfile

# Homepage dashboard config
!ubuntu/homepage/
!ubuntu/homepage/*.yaml

# Immich compose (env is secret, use .env.example)
!ubuntu/immich/
!ubuntu/immich/docker-compose.yml
!ubuntu/immich/.env.example

# Paperless compose
!ubuntu/paperless-ngx/
!ubuntu/paperless-ngx/docker-compose.yml

# ========================================
# NixOS configuration
# ========================================
!nixos/
!nixos/**

# Ignore sops secrets file (contains encrypted secrets, but we allow it)
# nixos/secrets/secrets.yaml is encrypted so it IS safe to commit

# ========================================
# Home Assistant node
# ========================================
!homeassistant/
!homeassistant/**

# Ignore HA secrets and runtime files
homeassistant/secrets.yaml
homeassistant/go2rtc.yaml
homeassistant/.storage/
homeassistant/home-assistant_v2.db*
homeassistant/home-assistant.log*
homeassistant/zigbee.db*
homeassistant/deps/
homeassistant/tts/
homeassistant/.HA_VERSION
homeassistant/.cloud/
homeassistant/.ha_run.lock
homeassistant/custom_components/
